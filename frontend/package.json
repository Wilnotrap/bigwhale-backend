{
  "version": "1.0.0",
  "description": "Frontend da plataforma de trading Nautilus Automação",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "glob": "^8.1.0",
    "webpack-bundle-analyzer": "^4.9.0"
  },
  "dependencies": {
    "@emotion/react": "^11.10.0",
    "@emotion/styled": "^11.10.0",
    "@mui/icons-material": "^5.11.0",
    "@mui/material": "^5.11.0",
    "@mui/x-data-grid": "^5.17.0",
    "axios": "^1.3.0",
    "chart.js": "^4.2.0",
    "date-fns": "^2.29.0",
    "html2canvas": "^1.4.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-lottie": "^1.2.10",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "react-toastify": "^9.1.0"
  },
  "proxy": "http://localhost:5000",
  "name": "bit-nova-frontend",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "main": "index.js",
  "scripts": {
    "analyze": "npm run build:prod && npx bundle-analyzer build/static/js/*.js",
    "build:secure": "cross-env NODE_ENV=production GENERATE_SOURCEMAP=false REACT_APP_ENVIRONMENT=production npm run build",
    "eject": "react-scripts eject",
    "test": "react-scripts test",
    "build": "npm run build:clean && react-scripts build",
    "lighthouse": "lighthouse https://https://site-hk5heaw7d.godaddysites.com --output html --output-path ./lighthouse-report.html",
    "build:clean": "node scripts/remove-logs.js",
    "build:prod": "cross-env NODE_ENV=production GENERATE_SOURCEMAP=false npm run build",
    "build:dev": "react-scripts build",
    "security:audit": "npm audit --audit-level moderate",
    "deploy:prepare": "npm run security:audit && npm run build:secure",
    "test:security": "node scripts/test-security.js",
    "start": "react-scripts start",
    "security:fix": "npm audit fix"
  }
}
