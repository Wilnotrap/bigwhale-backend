# Configuração para desenvolvimento local temporário
# Use este arquivo quando o backend do Render estiver inacessível

REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENVIRONMENT=local
REACT_APP_DEBUG=true

# Para usar esta configuração:
# 1. Renomeie este arquivo para .env.production
# 2. Inicie o backend local na pasta backend: python app.py
# 3. Faça o deploy do frontend com esta configuração